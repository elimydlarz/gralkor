{
  "name": "@susu-eng/gralkor",
  "version": "8.0.0",
  "description": "OpenClaw memory plugin powered by Graphiti knowledge graphs and FalkorDB",
  "type": "module",
  "main": "./dist/index.js",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc"
  },
  "files": [
    "dist",
    "server/Dockerfile",
    "server/main.py",
    "server/requirements.txt",
    "openclaw.plugin.json",
    "docker-compose.yml",
    "config.yaml",
    ".env.example"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/susu-eng/gralkor.git"
  },
  "homepage": "https://github.com/susu-eng/gralkor#readme",
  "bugs": {
    "url": "https://github.com/susu-eng/gralkor/issues"
  },
  "author": "susu-eng",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "graphiti",
    "falkordb",
    "knowledge-graph",
    "memory",
    "ai-agent"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "openclaw": ">= 2026.1.26"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT"
}
