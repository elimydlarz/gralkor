{
  "id": "memory-gralkor",
  "kind": "memory",
  "name": "Gralkor Memory",
  "description": "Persistent, temporally-aware memory via Graphiti knowledge graphs and FalkorDB",
  "configSchema": {
    "type": "object",
    "properties": {
      "graphitiUrl": {
        "type": "string",
        "default": "http://localhost:8000",
        "description": "URL of the Graphiti REST API"
      },
      "groupIdStrategy": {
        "type": "string",
        "enum": ["per-user", "per-conversation", "global"],
        "default": "per-user",
        "description": "How to partition the knowledge graph"
      },
      "autoCapture": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Automatically capture conversations into the graph"
          }
        }
      },
      "autoRecall": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Automatically recall relevant context before agent runs"
          },
          "maxResults": {
            "type": "number",
            "default": 5,
            "description": "Maximum number of facts to inject as context"
          }
        }
      }
    }
  },
  "uiHints": {
    "graphitiUrl": {
      "label": "Graphiti API URL",
      "placeholder": "http://localhost:8000"
    },
    "groupIdStrategy": {
      "label": "Graph Partitioning",
      "placeholder": "per-user"
    },
    "autoCapture.enabled": {
      "label": "Auto-capture conversations"
    },
    "autoRecall.enabled": {
      "label": "Auto-recall context"
    },
    "autoRecall.maxResults": {
      "label": "Max auto-recall results"
    }
  }
}
