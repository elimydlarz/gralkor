# Required (or one of the alternative provider keys below)
GOOGLE_API_KEY=

# Server bind port (default 4000)
HOST_PORT=4000

# Where embedded falkordblite stores its data.
# Default: $EXTERNAL_DIR/data/falkordb (resolved by serve.sh)
# FALKORDB_DATA_DIR=/absolute/path/to/data

# Optional alternative LLM providers — only set if your config selects them
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
